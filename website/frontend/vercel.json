{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://kiko-api.railway.app/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://kiko-api.railway.app/socket.io/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://kiko-api.railway.app/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
